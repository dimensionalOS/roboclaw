# DimOS MCP server environment variables (used by the Python side, not the OpenClaw plugin)
# Copy this file to .env and fill in the values before running `uv run dimos ...`

# OpenAI API key used by DimOS for LLM-powered robot control
OPENAI_API_KEY=

# IP address of the robot (e.g., Unitree Go2)
ROBOT_IP=
